{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "server-debug",
      "configurePreset": "debug",
      "targets": ["iris_server"]
    },
    {
      "name": "client-debug",
      "configurePreset": "debug",
      "targets": ["iris_client"]
    },
    {
      "name": "server-release",
      "configurePreset": "release",
      "targets": ["iris_server"]
    },
    {
      "name": "client-release",
      "configurePreset": "release",
      "targets": ["iris_client"]
    }
  ]
}
